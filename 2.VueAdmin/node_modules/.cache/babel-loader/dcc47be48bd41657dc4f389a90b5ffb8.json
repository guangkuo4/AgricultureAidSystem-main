{"remainingRequest":"D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\2.VueAdmin\\node_modules\\babel-loader\\lib\\index.js!D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\2.VueAdmin\\node_modules\\cache-loader\\dist\\cjs.js??ref--1-0!D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\2.VueAdmin\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\2.VueAdmin\\src\\views\\modules\\yonghu\\add-or-update.vue?vue&type=script&lang=js","dependencies":[{"path":"D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\2.VueAdmin\\src\\views\\modules\\yonghu\\add-or-update.vue","mtime":1775418550828},{"path":"D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\2.VueAdmin\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1775472968682},{"path":"D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\2.VueAdmin\\node_modules\\babel-loader\\lib\\index.js","mtime":1775472968751},{"path":"D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\2.VueAdmin\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1775472968682},{"path":"D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\2.VueAdmin\\node_modules\\vue-loader\\lib\\index.js","mtime":1775472967752}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["isNumber","isIntNumer","isEmail","isPhone","isMobile","isURL","checkIdCard","data","self","validateIdCard","rule","value","callback","Error","validateUrl","validateMobile","validatePhone","validateEmail","validateNumber","validateIntNumber","id","type","ro","yonghuzhanghao","mima","yonghuxingming","xingbie","yonghudianhua","touxiang","money","vip","ruleForm","xingbieOptions","vipOptions","rules","required","message","trigger","validator","props","computed","components","created","methods","download","file","window","open","init","info","logistics","obj","$storage","getObj","o","$http","url","get","method","then","code","json","$message","error","msg","split","reg","RegExp","