nlei: '',\n\t\t\t\tkechengzhaopian: '',\n\t\t\t\tkechengshipin: '',\n\t\t\t\twendangziliao: '',\n\t\t\t\tkechengjianjie: '',\n\t\t\t\tkechengxiangqing: '',\n\t\t\t},\n\t\t\n\t\t\tkechengfenleiOptions: [],\n\n\t\t\t\n\t\t\trules: {\n\t\t\t\tkechengbiaoti: [\n\t\t\t\t],\n\t\t\t\tkechengfenlei: [\n\t\t\t\t],\n\t\t\t\tkechengzhaopian: [\n\t\t\t\t],\n\t\t\t\tkechengshipin: [\n\t\t\t\t],\n\t\t\t\twendangziliao: [\n\t\t\t\t],\n\t\t\t\tkechengjianjie: [\n\t\t\t\t],\n\t\t\t\tkechengxiangqing: [\n\t\t\t\t],\n\t\t\t\tdiscussnum: [\n\t\t\t\t\t{ validator: validateIntNumber, trigger: 'blur' },\n\t\t\t\t],\n\t\t\t\tstoreupnum: [\n\t\t\t\t\t{ validator: validateIntNumber, trigger: 'blur' },\n\t\t\t\t],\n\t\t\t}\n\t\t};\n\t},\n\tprops: [\"parent\"],\n\tcomputed: {\n\n\n\n\t},\n    components: {\n    },\n\tcreated() {\n\t},\n\tmethods: {\n\t\t\n\t\t// дёӢиҪҪ\n\t\tdownload(file){\n\t\t\twindow.open(`${file}`)\n\t\t},\n\t\t// еҲқе§ӢеҢ–\n\t\tinit(id,type) {\n\t\t\tif (id) {\n\t\t\t\tthis.id = id;\n\t\t\t\tthis.type = type;\n\t\t\t}\n\t\t\tif(this.type=='info'||this.type=='else'){\n\t\t\t\tthis.info(id);\n\t\t\t}else if(this.type=='logistics'){\n\t\t\t\tthis.logistics=false;\n\t\t\t\tthis.info(id);\n\t\t\t}else if(this.type=='cross'){\n\t\t\t\tvar obj = this.$storage.getObj('crossObj');\n\t\t\t\tfor (var o in obj){\n\t\t\t\t\t\tif(o=='kechengbiaoti'){\n\t\t\t\t\t\t\tthis.ruleForm.kechengbiaoti = obj[o];\n\t\t\t\t\t\t\tthis.ro.kechengbiaoti = true;\n\t\t\t\t\t\t\tcontinue;\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif(o=='kechengfenlei'){\n\t\t\t\t\t\t\tthis.ruleForm.kechengfenlei = obj[o];\n\t\t\t\t\t\t\tthis.ro.kechengfenlei = true;\n\t\t\t\t\t\t\tcontinue;\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif(o=='kechengzhaopian'){\n\t\t\t\t\t\t\tthis.ruleForm.kechengzhaopian = obj[o];\n\t\t\t\t\t\t\tthis.ro.kechengzhaopian = true;\n\t\t\t\t\t\t\tcontinue;\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif(o=='kechengshipin'){\n\t\t\t\t\t\t\tthis.ruleForm.kechengshipin = obj[o];\n\t\t\t\t\t\t\tthis.ro.kechengshipin = true;\n\t\t\t\t\t\t\tcontinue;\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif(o=='wendangziliao'){\n\t\t\t\t\t\t\tthis.ruleForm.wendangziliao = obj[o];\n\t\t\t\t\t\t\tthis.ro.wendangziliao = true;\n\t\t\t\t\t\t\tcontinue;\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif(o=='kechengjianjie'){\n\t\t\t\t\t\t\tthis.ruleForm.kechengjianjie = obj[o];\n\t\t\t\t\t\t\tthis.ro.kechengjianjie = true;\n\t\t\t\t\t\t\tcontinue;\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif(o=='kechengxiangqing'){\n\t\t\t\t\t\t\tthis.ruleForm.kechengxiangqing = obj[o];\n\t\t\t\t\t\t\tthis.ro.kechengxiangqing = true;\n\t\t\t\t\t\t\tcontinue;\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif(o=='discussnum'){\n\t\t\t\t\t\t\tthis.ruleForm.discussnum = obj[o];\n\t\t\t\t\t\t\tthis.ro.discussnum = true;\n\t\t\t\t\t\t\tcontinue;\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif(o=='storeupnum'){\n\t\t\t\t\t\t\tthis.ruleForm.storeupnum = obj[o];\n\t\t\t\t\t\t\tthis.ro.storeupnum = true;\n\t\t\t\t\t\t\tcontinue;\n\t\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\t\n\n\n\n\n\n\n\n\n\n\t\t\t}\n\t\t\t\n\t\t\t// иҺ·еҸ–з”ЁжҲ·дҝЎжҒҜ\n\t\t\tthis.$http({\n\t\t\t\turl: `${this.$storage.get('sessionTable')}/session`,\n\t\t\t\tmethod: \"get\"\n\t\t\t}).then(({ data }) => {\n\t\t\t\tif (data && data.code === 0) {\n\t\t\t\t\t\n\t\t\t\t\tvar json = data.data;\n\t\t\t\t} else {\n\t\t\t\t\tthis.$message.error(data.msg);\n\t\t\t\t}\n\t\t\t});\n\t\t\t\n            this.kechengfenleiOptions = \"з§ҚжӨҚжҠҖжңҜ,е…»ж®–жҠҖжңҜ,еҶңжңәдҪҝз”Ё,е…¶д»–\".split(',')\n\t\t\t\n\t\t},\n    // еӨҡзә§иҒ”еҠЁеҸӮж•°\n\n    info(id) {\n      this.$http({\n        url: `nongjixuetang/info/${id}`,\n        method: \"get\"\n      }).then(({ data }) => {\n        if (data && data.code === 0) {\n        this.ruleForm = data.data;\n        //и§ЈеҶіеүҚеҸ°дёҠдј еӣҫзүҮеҗҺеҸ°дёҚжҳҫзӨәзҡ„й—®йўҳ\n        let reg=new RegExp('../../../upload','g')//gд»ЈиЎЁе…ЁйғЁ\n        this.ruleForm.kechengxiangqing = this.ruleForm.kechengxiangqing.replace(reg,'../../../springboot2855f2n2/upload');\n        } else {\n          this.$message.error(data.msg);\n        }\n      });\n    },\n\n\n    // жҸ