essage.error(data.msg);\n\t\t\t\t}\n\t\t\t});\n\t\t},\n\t\tmethods: {\n\t\t\thandleCommand(name) {\n\t\t\t\tif (name == 'front') {\n\t\t\t\t\tthis.onIndexTap()\n\t\t\t\t} else if (name == 'logout') {\n\t\t\t\t\tthis.onLogout()\n\t\t\t\t} else if (name == 'board'){\n\t\t\t\t\tthis.toBoard()\n\t\t\t\t} else if (name == 'backUp'){\n\t\t\t\t\tthis.backUp()\n\t\t\t\t} else {\n\t\t\t\t\tlet router = this.$router\n\t\t\t\t\tname = '/'+name\n\t\t\t\t\trouter.push(name)\n\t\t\t\t}\n\t\t\t},\n\t\t\t\n\t\t\tonLogout() {\n\t\t\t\tlet storage = this.$storage\n\t\t\t\tlet router = this.$router\n\t\t\t\tstorage.clear()\n\t\t\t\tthis.$store.dispatch('tagsView/delAllViews')\n\t\t\t\trouter.replace({\n\t\t\t\t\tname: \"login\"\n\t\t\t\t});\n\t\t\t},\n\t\t\tonIndexTap(){\n\t\t\t\twindow.location.href = `${this.$base.indexUrl}`\n\t\t\t},\n\t\t}\n\t};\n</script>\n\n\n<style lang=\"scss\" scoped>\n\t.top-el-dropdown-menu {\n\t\t\t\tborder: 1px solid #EBEEF5;\n\t\t\t\tborder-radius: 4px;\n\t\t\t\tpadding: 10px 0;\n\t\t\t\tbox-shadow: 0 0px 0px 0 rgba(0,0,0,.1);\n\t\t\t\tmargin: 18px 0;\n\t\t\t\tbackground: #FFF;\n\t\t\t\tmin-width: 150px;\n\t\t\t}\n\t\n\t.top-el-dropdown-menu li.el-dropdown-menu__item.item1 {\n\t\t\t\tcursor: pointer;\n\t\t\t\tpadding: 0 20px;\n\t\t\t\tmargin: 0;\n\t\t\t\toutline: 0;\n\t\t\t\tcolor: #606266;\n\t\t\t\tbackground: #fff;\n\t\t\t\tfont-size: 14px;\n\t\t\t\tline-height: 36px;\n\t\t\t\tlist-style: none;\n\t\t\t}\n\t\n\t.top-el-dropdown-menu li.el-dropdown-menu__item.item1:hover {\n\t\t\t\tbackground: #ecf5ff;\n\t\t\t}\n\t\n\t.top-el-dropdown-menu li.el-dropdown-menu__item.item2 {\n\t\t\t\tcursor: pointer;\n\t\t\t\tpadding: 0 20px;\n\t\t\t\tmargin: 0;\n\t\t\t\toutline: 0;\n\t\t\t\tcolor: #606266;\n\t\t\t\tbackground: #fff;\n\t\t\t\tfont-size: 14px;\n\t\t\t\tline-height: 36px;\n\t\t\t\tlist-style: none;\n\t\t\t}\n\t\n\t.top-el-dropdown-menu li.el-dropdown-menu__item.item2:hover {\n\t\t\t\tbackground: #ecf5ff;\n\t\t\t}\n\t\n\t.top-el-dropdown-menu li.el-dropdown-m