ouselData() {\r\n      this.$http({\r\n        url: \"config/list\",\r\n        method: \"get\",\r\n        params: {\r\n          limit: 10\r\n        }\r\n      }).then(({ data }) => {\r\n        if (data && data.code === 0) {\r\n          this.carouselData = data.data.list;\r\n        }\r\n      }).catch(err => {\r\n        console.error('轮播图数据获取失败:', err);\r\n      });\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.carousel-container {\r\n  width: 100%;\r\n  margin-bottom: 20px;\r\n}\r\n</style>"]}]}