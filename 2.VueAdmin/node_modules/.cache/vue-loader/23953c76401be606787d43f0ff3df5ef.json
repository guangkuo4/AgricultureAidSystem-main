\"fontSize\":\"inherit\",\"color\":\"inherit\"}' class=\"upload\" v-if=\"type!='info' && !ro.wenzhangzhaopian\" label=\"文章照片\" prop=\"wenzhangzhaopian\">\n\t\t\t\t\t<file-upload\n\t\t\t\t\t\ttip=\"点击上传文章照片\"\n\t\t\t\t\t\taction=\"file/upload\"\n\t\t\t\t\t\t:limit=\"3\"\n\t\t\t\t\t\t:multiple=\"true\"\n\t\t\t\t\t\t:fileUrls=\"ruleForm.wenzhangzhaopian?ruleForm.wenzhangzhaopian:''\"\n\t\t\t\t\t\t@change=\"wenzhangzhaopianUploadChange\"\n\t\t\t\t\t></file-upload>\n\t\t\t\t</el-form-item>\n\t\t\t\t<el-form-item :style='{\"width\":\"48%\",\"margin\":\"0 0 30px 0\",\"fontSize\":\"inherit\",\"color\":\"inherit\"}' class=\"upload\" v-else-if=\"ruleForm.wenzhangzhaopian\" label=\"文章照片\" prop=\"wenzhangzhaopian\">\n\t\t\t\t\t<img v-if=\"ruleForm.wenzhangzhaopian.substring(0,4)=='http'\" class=\"upload-img\" style=\"margin-right:20px;\" v-bind:key=\"index\" :src=\"ruleForm.wenzhangzhaopian.split(',')[0]\" width=\"100\" height=\"100\">\n\t\t\t\t\t<img v-else class=\"upload-img\" style=\"margin-right:20px;\" v-bind:key=\"index\" v-for=\"(item,index) in ruleForm.wenzhangzhaopian.split(',')\" :src=\"$base.url+item\" width=\"100\" height=\"100\">\n\t\t\t\t</el-form-item>\n\t\t\t\t<el-form-item :style='{\"width\":\"48%\",\"margin\":\"0 0 30px 0\",\"fontSize\":\"inherit\",\"color\":\"inherit\"}' class=\"date\" v-if=\"type!='info'\" label=\"发布时间\" prop=\"fabushijian\">\n\t\t\t\t\t<el-date-picker\n\t\t\t\t\t\tformat=\"yyyy 年 MM 月 dd 日\"\n\t\t\t\t\t\tvalue-format=\"yyyy-MM-dd\"\n\t\t\t\t\t\tv-model=\"ruleForm.fabushijian\" \n\t\t\t\t\t\ttype=\"date\"\n\t\t\t\t\t\t:readonly=\"ro.fabushijian\"\n\t\t\t\t\t\tplaceholder=\"发布时间\"\n\t\t\t\t\t></el-date-picker> \n\t\t\t\t</el-form-item>\n\t\t\t\t<el-form-item :style='{\"width\":\"48%\",\"margin\":\"0 0 30px 0\",\"fontSize\":\"inherit\",\"color\":\"inherit\"}' class=\"input\" v-else-if=\"ruleForm.fabushijian\" label=\"发布时间\" prop=\"fabushijian\">\n\t\t\t\t\t<el-input v-model=\"ruleForm.fabushijian\" placeholder=\"发布时间\" readonly></el-input>\n\t