<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.MessageDao">

    <resultMap type="com.entity.MessageEntity" id="MessageMap">
        <id column="id" property="id" />
        <result column="addtime" property="addtime" />
        <result column="userid" property="userid" />
        <result column="title" property="title" />
        <result column="content" property="content" />
        <result column="type" property="type" />
        <result column="status" property="status" />
        <result column="related_id" property="relatedId" />
    </resultMap>

    <select id="selectListVO" resultType="com.entity.vo.MessageVO">
        SELECT * FROM message message
        <where> 1=1 ${ew.sqlSegment}</where>
    </select>

    <select id="selectVO" resultType="com.entity.vo.MessageVO">
        SELECT message.* FROM message message
        <where> 1=1 ${ew.sqlSegment}</where>
    </select>

    <select id="selectListView" resultType="com.entity.view.MessageView">
        SELECT message.* FROM message message
        <where> 1=1 ${ew.sqlSegment}</where>
    </select>

    <select id="selectView" resultType="com.entity.view.MessageView">
        SELECT * FROM message message
        <where> 1=1 ${ew.sqlSegment}</where>
    </select>

</mapper>
