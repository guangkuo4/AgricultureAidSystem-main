<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.ThumbsupDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.entity.ThumbsupEntity" id="thumbsupMap">
        <result property="refid" column="refid"/>
        <result property="tablename" column="tablename"/>
        <result property="userid" column="userid"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.entity.vo.ThumbsupVO" >
		SELECT * FROM thumbsup  thumbsup         
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.entity.vo.ThumbsupVO" >
		SELECT  thumbsup.* FROM thumbsup  thumbsup  
		<where> 1=1 ${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.entity.view.ThumbsupView" >

		SELECT  thumbsup.* FROM thumbsup  thumbsup         
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.ThumbsupView" >
		SELECT * FROM thumbsup  thumbsup <where> 1=1 ${ew.sqlSegment}</where>
	</select>



</mapper>
