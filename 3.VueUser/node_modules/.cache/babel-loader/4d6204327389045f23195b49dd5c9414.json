{"remainingRequest":"D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\node_modules\\babel-loader\\lib\\index.js!D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\node_modules\\cache-loader\\dist\\cjs.js??ref--1-0!D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\src\\components\\MessageNotification.vue?vue&type=script&lang=js","dependencies":[{"path":"D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\src\\components\\MessageNotification.vue","mtime":1775857758655},{"path":"D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1775473901792},{"path":"D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\node_modules\\babel-loader\\lib\\index.js","mtime":1775473903160},{"path":"D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1775473901792},{"path":"D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\node_modules\\vue-loader\\lib\\index.js","mtime":1775473903727},{"path":"D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1775473901792},{"path":"D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\node_modules\\babel-loader\\lib\\index.js","mtime":1775473903160},{"path":"D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1775473901792},{"path":"D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\node_modules\\vue-loader\\lib\\index.js","mtime":1775473903727}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["data","messages","unreadCount","mounted","getMessages","methods","userid","localStorage","getItem","$http","get","params","then","res","code","page","list","slice","filter","m","status","length","catch","err","console","error","handleCommand","id","post","message","find","markAllRead","unreadMessages","ids","map","forEach","goToMessageCenter","$router","push","formatTime","time","date","Date","toLocaleString"],"sources":["src/components/MessageNotification.vue"],"sourcesContent":["<template>\n  <div class=\"message-notification\">\n    <el-dropdown trigger=\"click\" @command=\"handleCommand\">\n      <div class=\"notification-icon\" @click=\"getMessages\">\n        <i class=\"el-icon-bell\"></i>\n        <span v-if=\"unreadCount > 0\" class=\"unread-badge\">{{ unreadCount }}</span>\n      </div>\n      <el-dropdown-menu slot=\"dropdown\">\n        <el-dropdown-item v-if=\"messages.length === 0\" disabled>\n          暂无消息\n        </el-dropdown-item>\n        <el-dropdown-item\n          v-for=\"message in messages\"\n          :key=\"message.id\"\n          :command=\"message.id\"\n          :class=\"{ 'unread': message.status === '未读' }\"\n        >\n          <div class=\"message-item\">\n            <div class=\"message-title\">{{ message.title }}</div>\n            <div class=\"message-content\">{{ message.content }}</div>\n            <div class=\"message-time\">{{ formatTime(message.addtime) }}</div>\n          </div>\n        </el-dropdown-item>\n        <el-dropdown-item divided @click=\"markAllRead\">\n          标记全部已读\n        </el-dropdown-item>\n        <el-dropdown-item @click=\"goToMessageCenter\">\n          查看全部消息\n        </el-dropdown-item>\n      </el-dropdown-menu>\n    </el-dropdown>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      messages: [],\n      unreadCount: 0\n    }\n  },\n  mounted() {\n    this.getMessages()\n  },\n  methods: {\n    getMessages() {\n      const userid = localStorage.getItem('frontUserid')\n      if (!userid) {\n        this.messages = []\n        this.unreadCount = 0\n        return\n      }\n\n      this.$http.get('/message/list', {\n        params: { userid: userid }\n      }).then(res => {\n        if (res.data.code === 0) {\n          this.messages = (res.data.page.list || []).slice(0, 10) // 下拉最多显示10条\n          this.unreadCount = this.messages.filter(m => m.status === '未读').length\n        }\n      }).catch(err => {\n        console.error('获取消息失败:', err)\n      })\n    },\n    handleCommand(id) {\n      // 标记消息为已读\n      this.$http.post('/message/update', {\n        id: id,\n        status: '已读'\n      }).then(res => {\n        if (res.data.code === 0) {\n          const message = this.messages.find(m => m.id === id)\n          if (message) {\n            message.status = '已读'\n            this.unreadCount--\n          }\n        }\n      }).catch(err => {\n        console.error('标记消息已读失败:', err)\n      })\n    },\n    markAllRead() {\n      const unreadMessages = this.messages.filter(m => m.status === '未读')\n      const ids = unreadMessages.map(m => m.id)\n      if (ids.length === 0) return\n\n      this.$http.post('/message/update', {\n        ids: ids,\n        status: '已读'\n      }).then(res => {\n        if (res.data.code === 0) {\n          unreadMessages.forEach(m => {\n            m.status = '已读'\n          })\n          this.unreadCount = 0\n        }\n      }).catch(err => {\n        console.error('标记全部已读失败:', err)\n      })\n    },\n    goToMessageCenter() {\n      this.$router.push('/message')\n    },\n    formatTime(time) {\n      if (!time) return ''\n      const date = new Date(time)\n      return date.toLocaleString()\n    }\n  }\n}\n</script>\n\n<style scoped>\n.message-notification {\n  position: relative;\n}\n\n.notification-icon {\n  position: relative;\n  cursor: pointer;\n  font-size: 20px;\n  color: #666;\n  padding: 0 10px;\n\n  &:hover {\n    color: #667eea;\n  }\n}\n\n.unread-badge {\n  position: absolute;\n  top: -5px;\n  right: 5px;\n  background: #ff4d4f;\n  color: white;\n  font-size: 12px;\n  border-radius: 50%;\n  width: 18px;\n  height: 18px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.message-item {\n  max-width: 300px;\n  padding: 10px;\n  border-bottom: 1px solid #f0f0f0;\n  \n  &:last-child {\n    border-bottom: none;\n  }\n}\n\n.message-title {\n  font-weight: 600;\n  margin-bottom: 5px;\n  color: #333;\n}\n\n.message-content {\n  font-size: 14px;\n  color: #666;\n  margin-bottom: 5px;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  display: -webkit-box;\n  -webkit-line-clamp: 2;\n  -webkit-box-orient: vertical;\n}\n\n.message-time {\n  font-size: 12px;\n  color: #999;\n}\n\n.unread {\n  background: #f5f7fa;\n}\n</style>\n"],"mappings":"AAmCA;EACAA,KAAA;IACA;MACAC,QAAA;MACAC,WAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,WAAA;EACA;EACAC,OAAA;IACAD,YAAA;MACA,MAAAE,MAAA,GAAAC,YAAA,CAAAC,OAAA;MACA,KAAAF,MAAA;QACA,KAAAL,QAAA;QACA,KAAAC,WAAA;QACA;MACA;MAEA,KAAAO,KAAA,CAAAC,GAAA;QACAC,MAAA;UAAAL,MAAA,EAAAA;QAAA;MACA,GAAAM,IAAA,CAAAC,GAAA;QACA,IAAAA,GAAA,CAAAb,IAAA,CAAAc,IAAA;UACA,KAAAb,QAAA,IAAAY,GAAA,CAAAb,IAAA,CAAAe,IAAA,CAAAC,IAAA,QAAAC,KAAA;UACA,KAAAf,WAAA,QAAAD,QAAA,CAAAiB,MAAA,CAAAC,CAAA,IAAAA,CAAA,CAAAC,MAAA,WAAAC,MAAA;QACA;MACA,GAAAC,KAAA,CAAAC,GAAA;QACAC,OAAA,CAAAC,KAAA,YAAAF,GAAA;MACA;IACA;IACAG,cAAAC,EAAA;MACA;MACA,KAAAlB,KAAA,CAAAmB,IAAA;QACAD,EAAA,EAAAA,EAAA;QACAP,MAAA;MACA,GAAAR,IAAA,CAAAC,GAAA;QACA,IAAAA,GAAA,CAAAb,IAAA,CAAAc,IAAA;UACA,MAAAe,OAAA,QAAA5B,QAAA,CAAA6B,IAAA,CAAAX,CAAA,IAAAA,CAAA,CAAAQ,EAAA,KAAAA,EAAA;UACA,IAAAE,OAAA;YACAA,OAAA,CAAAT,MAAA;YACA,KAAAlB,WAAA;UACA;QACA;MACA,GAAAoB,KAAA,CAAAC,GAAA;QACAC,OAAA,CAAAC,KAAA,cAAAF,GAAA;MACA;IACA;IACAQ,YAAA;MACA,MAAAC,cAAA,QAAA/B,QAAA,CAAAiB,MAAA,CAAAC,CAAA,IAAAA,CAAA,CAAAC,MAAA;MACA,MAAAa,GAAA,GAAAD,cAAA,CAAAE,GAAA,CAAAf,CAAA,IAAAA,CAAA,CAAAQ,EAAA;MACA,IAAAM,GAAA,CAAAZ,MAAA;MAEA,KAAAZ,KAAA,CAAAmB,IAAA;QACAK,GAAA,EAAAA,GAAA;QACAb,MAAA;MACA,GAAAR,IAAA,CAAAC,GAAA;QACA,IAAAA,GAAA,CAAAb,IAAA,CAAAc,IAAA;UACAkB,cAAA,CAAAG,OAAA,CAAAhB,CAAA;YACAA,CAAA,CAAAC,MAAA;UACA;UACA,KAAAlB,WAAA;QACA;MACA,GAAAoB,KAAA,CAAAC,GAAA;QACAC,OAAA,CAAAC,KAAA,cAAAF,GAAA;MACA;IACA;IACAa,kBAAA;MACA,KAAAC,OAAA,CAAAC,IAAA;IACA;IACAC,WAAAC,IAAA;MACA,KAAAA,IAAA;MACA,MAAAC,IAAA,OAAAC,IAAA,CAAAF,IAAA;MACA,OAAAC,IAAA,CAAAE,cAAA;IACA;EACA;AACA","ignoreList":[]}]}