{"remainingRequest":"D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\node_modules\\thread-loader\\dist\\cjs.js!D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\node_modules\\babel-loader\\lib\\index.js!D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\src\\utils\\errorHandler.js","dependencies":[{"path":"D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\src\\utils\\errorHandler.js","mtime":1775834621499},{"path":"D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1775473901792},{"path":"D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\node_modules\\thread-loader\\dist\\cjs.js","mtime":1775473901792},{"path":"D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\node_modules\\babel-loader\\lib\\index.js","mtime":1775473903160}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["ERROR_TYPES","NETWORK","AUTH","VALIDATION","SERVER","UNKNOWN","ERROR_MESSAGES","ErrorHandler","handleError","error","customMessage","console","errorType","errorMessage","message","includes","response","status","setTimeout","window","location","href","data","showError","type","$message","duration","showClose","alert","showSuccess","success","showWarning","warning","showInfo","info","wrapAsync","asyncFn","args"],"sources":["D:/AgricultureAidSystem/AgricultureAidSystem-main/3.VueUser/src/utils/errorHandler.js"],"sourcesContent":["/**\n * 错误处理工具\n * 用于统一处理系统中的错误，为用户提供明确的错误提示\n */\n\n// 错误类型定义\nconst ERROR_TYPES = {\n  NETWORK: 'network',\n  AUTH: 'auth',\n  VALIDATION: 'validation',\n  SERVER: 'server',\n  UNKNOWN: 'unknown'\n};\n\n// 错误消息映射\nconst ERROR_MESSAGES = {\n  [ERROR_TYPES.NETWORK]: '网络连接失败，请检查网络设置后重试',\n  [ERROR_TYPES.AUTH]: '登录已过期，请重新登录',\n  [ERROR_TYPES.VALIDATION]: '输入信息有误，请检查后重试',\n  [ERROR_TYPES.SERVER]: '服务器错误，请稍后重试',\n  [ERROR_TYPES.UNKNOWN]: '未知错误，请稍后重试'\n};\n\n/**\n * 错误处理类\n */\nclass ErrorHandler {\n  /**\n   * 处理错误\n   * @param {Error} error - 错误对象\n   * @param {string} customMessage - 自定义错误消息\n   */\n  static handleError(error, customMessage = '') {\n    console.error('Error occurred:', error);\n    \n    let errorType = ERROR_TYPES.UNKNOWN;\n    let errorMessage = customMessage || ERROR_MESSAGES[ERROR_TYPES.UNKNOWN];\n    \n    // 根据错误类型判断\n    if (error.message && error.message.includes('Network Error')) {\n      errorType = ERROR_TYPES.NETWORK;\n      errorMessage = customMessage || ERROR_MESSAGES[ERROR_TYPES.NETWORK];\n    } else if (error.response && error.response.status === 401) {\n      errorType = ERROR_TYPES.AUTH;\n      errorMessage = customMessage || ERROR_MESSAGES[ERROR_TYPES.AUTH];\n      // 跳转到登录页面\n      setTimeout(() => {\n        window.location.href = '/login';\n      }, 1000);\n    } else if (error.response && error.response.status === 400) {\n      errorType = ERROR_TYPES.VALIDATION;\n      errorMessage = customMessage || (error.response.data && error.response.data.message) || ERROR_MESSAGES[ERROR_TYPES.VALIDATION];\n    } else if (error.response && error.response.status >= 500) {\n      errorType = ERROR_TYPES.SERVER;\n      errorMessage = customMessage || ERROR_MESSAGES[ERROR_TYPES.SERVER];\n    }\n    \n    // 显示错误提示\n    this.showError(errorMessage);\n    \n    return {\n      type: errorType,\n      message: errorMessage\n    };\n  }\n  \n  /**\n   * 显示错误提示\n   * @param {string} message - 错误消息\n   */\n  static showError(message) {\n    // 检查是否存在 Element UI 的 $message 方法\n    if (window.$message) {\n      window.$message.error({\n        message: message,\n        duration: 3000,\n        showClose: true\n      });\n    } else {\n      // 否则使用浏览器默认的 alert\n      alert(message);\n    }\n  }\n  \n  /**\n   * 显示成功提示\n   * @param {string} message - 成功消息\n   */\n  static showSuccess(message) {\n    // 检查是否存在 Element UI 的 $message 方法\n    if (window.$message) {\n      window.$message.success({\n        message: message,\n        duration: 2000,\n        showClose: true\n      });\n    } else {\n      // 否则使用浏览器默认的 alert\n      alert(message);\n    }\n  }\n  \n  /**\n   * 显示警告提示\n   * @param {string} message - 警告消息\n   */\n  static showWarning(message) {\n    // 检查是否存在 Element UI 的 $message 方法\n    if (window.$message) {\n      window.$message.warning({\n        message: message,\n        duration: 3000,\n        showClose: true\n      });\n    } else {\n      // 否则使用浏览器默认的 alert\n      alert(message);\n    }\n  }\n  \n  /**\n   * 显示信息提示\n   * @param {string} message - 信息消息\n   */\n  static showInfo(message) {\n    // 检查是否存在 Element UI 的 $message 方法\n    if (window.$message) {\n      window.$message.info({\n        message: message,\n        duration: 2000,\n        showClose: true\n      });\n    } else {\n      // 否则使用浏览器默认的 alert\n      alert(message);\n    }\n  }\n  \n  /**\n   * 包装异步函数，添加错误处理\n   * @param {Function} asyncFn - 异步函数\n   * @param {string} customMessage - 自定义错误消息\n   * @returns {Function} 包装后的函数\n   */\n  static wrapAsync(asyncFn, customMessage = '') {\n    return async (...args) => {\n      try {\n        return await asyncFn(...args);\n      } catch (error) {\n        this.handleError(error, customMessage);\n        throw error;\n      }\n    };\n  }\n}\n\nexport default ErrorHandler;"],"mappings":"AAAA;AACA;AACA;AACA;;AAEA;AACA,MAAMA,WAAW,GAAG;EAClBC,OAAO,EAAE,SAAS;EAClBC,IAAI,EAAE,MAAM;EACZC,UAAU,EAAE,YAAY;EACxBC,MAAM,EAAE,QAAQ;EAChBC,OAAO,EAAE;AACX,CAAC;;AAED;AACA,MAAMC,cAAc,GAAG;EACrB,CAACN,WAAW,CAACC,OAAO,GAAG,mBAAmB;EAC1C,CAACD,WAAW,CAACE,IAAI,GAAG,aAAa;EACjC,CAACF,WAAW,CAACG,UAAU,GAAG,eAAe;EACzC,CAACH,WAAW,CAACI,MAAM,GAAG,aAAa;EACnC,CAACJ,WAAW,CAACK,OAAO,GAAG;AACzB,CAAC;;AAED;AACA;AACA;AACA,MAAME,YAAY,CAAC;EACjB;AACF;AACA;AACA;AACA;EACE,OAAOC,WAAWA,CAACC,KAAK,EAAEC,aAAa,GAAG,EAAE,EAAE;IAC5CC,OAAO,CAACF,KAAK,CAAC,iBAAiB,EAAEA,KAAK,CAAC;IAEvC,IAAIG,SAAS,GAAGZ,WAAW,CAACK,OAAO;IACnC,IAAIQ,YAAY,GAAGH,aAAa,IAAIJ,cAAc,CAACN,WAAW,CAACK,OAAO,CAAC;;IAEvE;IACA,IAAII,KAAK,CAACK