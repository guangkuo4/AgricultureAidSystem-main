{"remainingRequest":"D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\node_modules\\thread-loader\\dist\\cjs.js!D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\node_modules\\babel-loader\\lib\\index.js!D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\src\\utils\\errorHandler.js","dependencies":[{"path":"D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\src\\utils\\errorHandler.js","mtime":1775922927660},{"path":"D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1775473901792},{"path":"D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\node_modules\\thread-loader\\dist\\cjs.js","mtime":1775473901792},{"path":"D:\\AgricultureAidSystem\\AgricultureAidSystem-main\\3.VueUser\\node_modules\\babel-loader\\lib\\index.js","mtime":1775473903160}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["ERROR_TYPES","NETWORK","AUTH","VALIDATION","SERVER","UNKNOWN","ERROR_MESSAGES","ErrorHandler","handleError","error","customMessage","console","errorData","body","response","data","errorMessage","msg","message","includes","status","setTimeout","window","location","href","statusText","showError","type","$message","_getMessage","alert","showSuccess","success","showWarning","warning","showInfo","info","__vueApp__","Vue","prototype","wrapAsync","asyncFn","args"],"sources":["D:/AgricultureAidSystem/AgricultureAidSystem-main/3.VueUser/src/utils/errorHandler.js"],"sourcesContent":["/**\n * 错误处理工具\n * 用于统一处理系统中的错误，为用户提供明确的错误提示\n */\n\n// 错误类型定义\nconst ERROR_TYPES = {\n  NETWORK: 'network',\n  AUTH: 'auth',\n  VALIDATION: 'validation',\n  SERVER: 'server',\n  UNKNOWN: 'unknown'\n};\n\n// 错误消息映射\nconst ERROR_MESSAGES = {\n  [ERROR_TYPES.NETWORK]: '网络连接失败，请检查网络设置后重试',\n  [ERROR_TYPES.AUTH]: '登录已过期，请重新登录',\n  [ERROR_TYPES.VALIDATION]: '输入信息有误，请检查后重试',\n  [ERROR_TYPES.SERVER]: '服务器错误，请稍后重试',\n  [ERROR_TYPES.UNKNOWN]: '未知错误，请稍后重试'\n};\n\n/**\n * 错误处理类\n */\nclass ErrorHandler {\n  /**\n   * 处理错误\n   * @param {Error} error - 错误对象\n   * @param {string} customMessage - 自定义错误消息\n   */\n  static handleError(error, customMessage = '') {\n    console.error('Error occurred:', error);\n    // vue-resource 错误在 body 中，axios 在 response.data 中\n    const errorData = error.body || (error.response && error.response.data);\n    let errorMessage = customMessage || ERROR_MESSAGES[ERROR_TYPES.UNKNOWN];\n\n    if (errorData && errorData.msg) {\n      errorMessage = errorData.msg;\n    } else if (error.message && error.message.includes('Network Error')) {\n      errorMessage = customMessage || ERROR_MESSAGES[ERROR_TYPES.NETWORK];\n    } else if (error.status === 401) {\n      errorMessage = customMessage || ERROR_MESSAGES[ERROR_TYPES.AUTH];\n      setTimeout(() => { window.location.href = '/login' }, 1500);\n    } else if (error.status === 400) {\n      errorMessage = customMessage || ERROR_MESSAGES[ERROR_TYPES.VALIDATION];\n    } else if (error.status >= 500) {\n      errorMessage = customMessage || ERROR_MESSAGES[ERROR_TYPES.SERVER];\n    } else if (error.statusText) {\n      errorMessage = error.statusText;\n    }\n\n    this.showError(errorMessage);\n    return { type: ERROR_TYPES.UNKNOWN, message: errorMessage };\n  }\n\n  /**\n   * 显示错误提示\n   * @param {string} message - 错误消息\n   */\n  static showError(message) {\n    const $message = this._getMessage()\n    if ($message) {\n      $message.error(message)\n    } else {\n      console.error('Error:', message)\n      alert(message)\n    }\n  }\n\n  /**\n   * 显示成功提示\n   * @param {string} message - 成功消息\n   */\n  static showSuccess(message) {\n    const $message = this._getMessage()\n    if ($message) {\n      $message.success(message)\n    } else {\n      alert(message)\n    }\n  }\n\n  /**\n   * 显示警告提示\n   * @param {string} message - 警告消息\n   */\n  static showWarning(message) {\n    const $message = this._getMessage()\n    if ($message) {\n      $message.warning(message)\n    } else {\n      alert(message)\n    }\n  }\n\n  /**\n   * 显示信息提示\n   * @param {string} message - 信息消息\n   */\n  static showInfo(message) {\n    const $message = this._getMessage()\n    if ($message) {\n      $message.info(message)\n    } else {\n      alert(message)\n    }\n  }\n\n  /**\n   * 获取 Vue 实例的 $message\n   * @returns {Function|null}\n   */\n  static _getMessage() {\n    if (window.__vueApp__ && window.__vueApp__.$message) {\n      return window.__vueApp__.$message\n    }\n    if (Vue && Vue.prototype && Vue.prototype.$message) {\n      return Vue.prototype.$message\n    }\n    return null\n  }\n\n  /**\n   * 包装异步函数，添加错误处理\n   * @param {Function} asyncFn - 异步函数\n   * @param {string} customMessage - 自定义错误消息\n   * @returns {Function} 包装后的函数\n   */\n  static wrapAsync(asyncFn, customMessage = '') {\n    return async (...args) => {\n      try {\n        return await asyncFn(...args);\n      } catch (error) {\n        // 不再调用 handleError，避免显示通用兜底消息\n        // 错误已在上层 catch 中处理，这里只做静默日志\n        console.error('Async function error (已在上层处理):', error);\n      }\n    };\n  }\n}\n\nexport default ErrorHandler;\n\n"],"mappings":"AAAA;AACA;AACA;AACA;;AAEA;AACA,MAAMA,WAAW,GAAG;EAClBC,OAAO,EAAE,SAAS;EAClBC,IAAI,EAAE,MAAM;EACZC,UAAU,EAAE,YAAY;EACxBC,MAAM,EAAE,QAAQ;EAChBC,OAAO,EAAE;AACX,CAAC;;AAED;AACA,MAAMC,cAAc,GAAG;EACrB,CAACN,WAAW,CAACC,OAAO,GAAG,mBAAmB;EAC1C,CAACD,WAAW,CAACE,IAAI,GAAG,aAAa;EACjC,CAACF,WAAW,CAACG,UAAU,GAAG,eAAe;EACzC,CAACH,WAAW,CAACI,MAAM,GAAG,aAAa;EACnC,CAACJ,WAAW,CAACK,OAAO,GAAG;AACzB,CAAC;;AAED;AACA;AACA;AACA,MAAME,YAAY,CAAC;EACjB;AACF;AACA;AACA;AACA;EACE,OAAOC,WAAWA,CAACC,KAAK,EAAEC,aAAa,GAAG,EAAE,EAAE;IAC5CC,OAAO,CAACF,KAAK,CAAC,iBAAiB,EAAEA,KAAK,CAAC;IACvC;IACA,MAAMG,SAAS,GAAGH,KAAK,CAACI,IAAI,IAAKJ,KAAK,CAACK,QAAQ,IAAIL,KAAK,CAACK,QAAQ,CAACC,IAAK;IACvE,IAAIC,YAAY,GAAGN,aAAa,IAAIJ,cAAc,CAACN,WAAW,CAACK,OAAO,CAAC;IAEvE,IAAIO,SAAS,IAAIA,SAAS,CAACK,GAAG,EAAE;MAC9BD,YAAY,GAAGJ,SAAS,CAACK,GAAG;IAC9B,CAAC,MAAM,IAAIR,KAAK,CAACS,